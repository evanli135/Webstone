FROM python:3.12-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy dependency specs
COPY pyproject.toml .
COPY README.md .

# Install all dependencies including dev extras
RUN uv sync --all-extras

# Source and tests are bind-mounted in compose for hot reload
EXPOSE 8000

CMD ["uv", "run", "uvicorn", "whetstone.services.api.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
