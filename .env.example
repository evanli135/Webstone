# --- LLM ---
ANTHROPIC_API_KEY=your_api_key_here
MODEL_NAME=claude-sonnet-4-6

# --- Runtime ---
WEBSTONE_ENV=development
WEBSTONE_LOG_LEVEL=INFO
WEBSTONE_MAX_WORKERS=8
WEBSTONE_MAX_BRANCHES=256

# --- Memory ---
WEBSTONE_GRAPH_STORE_BACKEND=memory      # memory | neo4j | kuzu
WEBSTONE_VECTOR_STORE_BACKEND=memory     # memory | qdrant | pinecone | chroma
WEBSTONE_VECTOR_STORE_URL=
WEBSTONE_VECTOR_STORE_API_KEY=

# --- Queue ---
WEBSTONE_QUEUE_BACKEND=memory            # memory | redis
WEBSTONE_REDIS_URL=redis://localhost:6379/0

# --- Checkpoints ---
WEBSTONE_CHECKPOINT_BACKEND=memory      # memory | sqlite | postgres
WEBSTONE_DATABASE_URL=sqlite:///webstone.db

# --- Observability ---
WEBSTONE_OTEL_ENDPOINT=http://localhost:4317
WEBSTONE_OTEL_SERVICE_NAME=Webstone
WEBSTONE_METRICS_ENABLED=true
WEBSTONE_TRACING_ENABLED=true

# --- API ---
WEBSTONE_API_HOST=0.0.0.0
WEBSTONE_API_PORT=8000
WEBSTONE_API_WORKERS=1
