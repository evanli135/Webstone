# Normalize all text files to LF on commit
* text=auto eol=lf

# Force LF for shell scripts and configs
*.py text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
